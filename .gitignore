# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/

# Native
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo
assets/emptyWiki.html

# result of fetchHTML.mjs for debugging
scripts/fetchHTML/

# generated plugin from `npm run build:plugin`
# Not ignoring this, to prevent [stderr] None of these files exist:  * syncadaptor-ui.html
# assets/plugins/
@tiddly-gittly__tidgi-mobile.jks.base64.txt

build/
# prebuild
/android/
/ios

# Detox runtime artifacts
# Root artifacts generated by Detox runs (screenshots, logs, videos)
/artifacts/

# Keep e2e/artifacts/apks directory structure in git, but ignore downloaded APKs
e2e/artifacts/*
!e2e/artifacts/apks/
e2e/artifacts/apks/*
!e2e/artifacts/apks/.gitkeep

# Detox/Cucumber HTML reports
e2e/reports/
